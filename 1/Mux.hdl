// File name: projects/1/Mux.hdl
/** 
 * Multiplexor:
 * if (sel = 0) out = a, else out = b
 */
CHIP Mux {
    IN a, b, sel;
    OUT out;

    PARTS:
    Not(in=sel,out=i1);
    And(a=a,b=i1,out=i2);
    And(a=sel,b=b,out=i3);
    Or(a=i2,b=i3,out=out);
}