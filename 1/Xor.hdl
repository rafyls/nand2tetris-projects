// File name: projects/1/Xor.hdl
/**
 * Exclusive-or gate:
 * if ((a and Not(b)) or (Not(a) and b)) out = 1, else out = 0
 */
CHIP Xor {
    IN a, b;
    OUT out;

    PARTS:
    Not(in=a,out=i1);
    Not(in=b,out=i2);
    And(a=a,b=i2,out=i3);
    And(a=i1,b=b,out=i4);
    Or(a=i3,b=i4,out=out);
}